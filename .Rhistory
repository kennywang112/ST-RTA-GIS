geom_hline(yintercept = 0, color = "black", linewidth = 0.5) +
# 注意：因為每個小時的總件數不同，隨機區間(Ribbon)在件數尺度下會因時段而異
# 這裡我們先畫出 24 小時的偏差線
geom_line(data = obs_k_hourly,
aes(x = dist, y = deviation_k, color = hour_factor),
linewidth = 0.8, alpha = 0.8) +
scale_x_continuous(limits = c(0, 200)) +
scale_color_viridis_d(option = "turbo", name = "Hour of Day") +
labs(title = "Spatial Clustering Deviation (Accident Counts)",
subtitle = "Difference between Observed and Expected Number of Accidents",
x = "Distance to Nearest YouBike (m)",
y = "Deviation (Observed Count - Expected Count)") +
theme_minimal(base_family = "PingFang TC") +
theme(legend.position = "right",
legend.key.size = unit(0.4, "cm"),
legend.text = element_text(size = 8))
hourly_youbike_k_deviation
# 1. 先計算每個時段的總事故件數 (n_total)
hour_counts <- combined_sf %>%
st_drop_geometry() %>%
count(hour_factor, name = "n_total")
# 2. 修改資料：將比例轉換為件數 (K-style)
# 注意：這裡我們將 obs_cdf 和 deviation 都乘以 n_total
obs_k_hourly <- obs_cdf_hourly %>%
left_join(hour_counts, by = "hour_factor") %>%
mutate(
obs_k = obs_cdf * n_total,           # 實際累計件數
expected_k = mean * n_total,         # 隨機預期件數
deviation_k = deviation * n_total    # 偏離件數 (Obs - Exp)
)
# 3. 繪圖 (Y軸改為 deviation_k)
hourly_youbike_k_deviation <- ggplot() +
geom_hline(yintercept = 0, color = "black", linewidth = 0.5) +
# 注意：因為每個小時的總件數不同，隨機區間(Ribbon)在件數尺度下會因時段而異
# 這裡我們先畫出 24 小時的偏差線
geom_line(data = obs_k_hourly,
aes(x = dist, y = deviation_k, color = hour_factor),
linewidth = 0.8, alpha = 0.8) +
scale_x_continuous(limits = c(0, 200)) +
scale_color_viridis_d(option = "turbo", name = "Hour of Day") +
labs(title = "Spatial Clustering Deviation (Accident Counts)",
subtitle = "Difference between Observed and Expected Number of Accidents",
x = "Distance to Nearest YouBike (m)",
y = "Deviation (Observed Count - Expected Count)") +
theme_minimal(base_family = "PingFang TC") +
theme(legend.position = "right",
legend.key.size = unit(0.4, "cm"),
legend.text = element_text(size = 8))
hourly_youbike_k_deviation
df_sim_centered <- df_sim_baseline %>%
mutate(
lo_diff = lo - mean,
hi_diff = hi - mean,
mean_diff = 0
)
df_sim_centered
dist_grid
df_sim_baseline
df_sim_centered <- df_sim_baseline %>%
mutate(
lo_diff = lo,# - mean,
hi_diff = hi, #- mean,
# mean_diff = 0
mean = mean
)
obs_cdf_hourly <- combined_sf %>%
st_drop_geometry() %>%
group_by(hour_factor) %>%
reframe(
dist = dist_grid,
obs_cdf = ecdf(dist_to_nearest_youbike)(dist_grid)
) %>%
left_join(df_sim_baseline %>% select(dist, mean), by = "dist") %>%
mutate(deviation = obs_cdf - mean)
hourly_youbike_deviation <- ggplot() +
geom_hline(yintercept = 0, color = "black", linewidth = 0.5) +
geom_ribbon(data = df_sim_centered,
aes(x = dist, ymin = lo_diff, ymax = hi_diff),
fill = "grey70", alpha = 0.5) +
geom_line(data = df_sim_centered,
aes(x = dist, y = mean_diff, linetype = "Random Baseline (CSR)"),
color = "red", linewidth = 1) +
geom_line(data = obs_cdf_hourly,
aes(x = dist, y = deviation, color = hour_factor),
linewidth = 0.6, alpha = 0.8) +
scale_x_continuous(limits = c(0, 200)) +
scale_color_viridis_d(option = "turbo", name = "Hour of Day") +
scale_linetype_manual(name = "Baseline", values = c("Random Baseline (CSR)" = "dashed")) +
labs(title = "Spatial Clustering Deviation across 24 Hours",
subtitle = paste0("Difference from Random Baseline (", n_sim, " Simulations)"),
x = "Distance to Nearest YouBike (m)",
y = "Deviation from CSR (Observed CDF - Expected CDF)") +
theme_minimal() +
theme(legend.position = "right",
legend.key.size = unit(0.4, "cm"),
legend.text = element_text(size = 8))
print(hourly_youbike_deviation)
