library(lubridate)
# 1. 資料轉換與週分組
weekly_trends <- final_boundary_data %>%
mutate(
# 將 20240101 轉換為日期格式
date_parsed = ymd(發生日期),
# 將日期對齊到該週的週日 (或週一，可調整 unit = "weeks")
week_start = floor_date(date_parsed, unit = "week")
) %>%
# 過濾掉可能的異常日期 (如有)
filter(!is.na(week_start)) %>%
# 依照週起點計算事故總量
count(week_start, name = "accident_count")
# 2. 繪製時間序列圖
ggplot(weekly_trends, aes(x = week_start, y = accident_count)) +
geom_line(color = "#1f77b4", size = 1) +
geom_point(color = "#1f77b4", size = 2, alpha = 0.6) +
# 加入平滑趨勢線 (Loess)，幫助觀察整體走勢
geom_smooth(method = "loess", color = "red", linetype = "dashed", se = FALSE, span = 0.2) +
scale_x_date(date_labels = "%Y-%m", date_breaks = "1 month") +
labs(
title = "Weekly Trend of Traffic Accidents",
subtitle = "Data grouped by week start date",
x = "Date",
y = "Number of Accidents"
) +
theme_minimal(base_family = "PingFang TC") +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
plot.title = element_text(face = "bold", size = 16)
)
