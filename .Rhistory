overall_accident_cdf <- ecdf(plot_sf$current_dist)(dist_grid)
df_sim_baseline <- data.frame(
dist = dist_grid,
mean = overall_accident_cdf,
hi = apply(current_sim_matrix, 1, max),
lo = apply(current_sim_matrix, 1, min)
)
