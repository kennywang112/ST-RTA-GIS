library(sf)
library(tmap)
library(tidyverse)
# 1. 定義區域 (假設 trend_grid 內有 COUNTYNAME)
# 如果沒有，請確保先與行政區劃資料合併
north_counties <- c("臺北市", "新北市", "基隆市", "桃園市", "新竹市", "新竹縣", "宜蘭縣")
central_counties <- c("苗栗縣", "臺中市", "彰化縣", "南投縣", "雲林縣")
south_counties <- c("嘉義市", "嘉義縣", "臺南市", "高興市", "屏東縣")
# 2. 切換為靜態繪圖模式
tmap_mode("plot")
# 3. 定義統一的繪圖函數 (確保顏色與設定一致)
create_region_map <- function(data, region_name) {
tm_shape(data) +
tm_polygons(
col = "target_label",
palette = c(
"Dissipated" = "#74add1",
"Stable_Safe" = "#4575b4",
"Emergent" = "#fdae61",
"Persistent" = "#d73027"
),
border.col = "#bac8cc",
lwd = 0.1,
title = region_name) +
tm_shape(boundary) +
tm_borders(col = "grey20", lwd = 0.1, alpha = 0.3) +
tm_layout(
legend.show = FALSE, # 先關閉個別圖例，最後統一放或放某一張
frame = FALSE,
main.title = region_name,
main.title.size = 0.8,
main.title.position = "center"
)
}
# 4. 過濾資料並生成三張地圖
# 注意：這裡使用 st_filter 或根據 COUNTYNAME 篩選
map_north <- create_region_map(trend_grid %>% filter(COUNTYNAME %in% north_counties), "Northern Taiwan")
map_central <- create_region_map(trend_grid %>% filter(COUNTYNAME %in% central_counties), "Central Taiwan")
map_south <- create_region_map(trend_grid %>% filter(COUNTYNAME %in% south_counties), "Southern Taiwan")
# 5. 處理圖例 (單獨抓出一個有圖例的地圖作為參考，或在最後排版加入)
# 這裡我們讓最後一張地圖顯示圖例
map_south_with_legend <- map_south + tm_layout(legend.show = TRUE, legend.position = c("right", "bottom"))
# 6. 並排成一列 (1 row, 3 columns)
final_layout <- tmap_arrange(map_north, map_central, map_south_with_legend, ncol = 3)
# 7. 顯示並存檔
print(final_layout)
